{
  "cli": {
    "version": ">= 14.2.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "LIGHTNINGCSS_SKIP_MINIFY": "1"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "LIGHTNINGCSS_SKIP_MINIFY": "1"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
